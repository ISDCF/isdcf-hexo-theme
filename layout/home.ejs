<article class="post post--full">
  <header class="post__header">
    <h1 class="post__title"><%= page.title || '(untitled)' %></h1>
  </header>
  <div class="post__content">
    <%- page.content %>
  </div>
</article>

<% var recent = site.posts.sort('-date').toArray().sort(function(a, b){ return (b.sticky || 0) - (a.sticky || 0); }).slice(0, 5); %>
<% if (recent.length) { %>
  <section>
    <h2 class="section-title">Recent Announcements</h2>
    <div class="post-list">
      <% recent.forEach(function(post){ %>
        <%- partial('_partial/article', {post: post, index: true}) %>
      <% }) %>
    </div>
  </section>
<% } %>
